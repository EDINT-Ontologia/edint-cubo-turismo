@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix esadm: <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edinttur: <http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#> .
@prefix edintmeasure: <http://vocab.linkeddata.es/datosabiertos/def/measure#> .
@prefix sdmx-measure: <http://purl.org/linked-data/sdmx/2009/measure#> .
@prefix edintdimension: <http://vocab.linkeddata.es/datosabiertos/def/dimension#> .
@prefix sdmx-dimension: <http://purl.org/linked-data/sdmx/2009/dimension#> .
@base <https://www.w3.org/TR/vocab-data-cube/> .

<https://www.w3.org/TR/vocab-data-cube/> rdf:type owl:Ontology ;
                                          owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo/0.1.0> ;
                                          owl:imports <https://www.w3.org/TR/vocab-data-cube/> ;
                                          dc:created "2026-04-17"^^xsd:date ;
                                          dc:creator "Daniel Doña" ,
                                                     "Diego Conde Herreros" ,
                                                     "Edna Ruckhaus" ,
                                                     "Lucía Sánchez" ,
                                                     "Oscar Corcho" ,
                                                     "Socorro Bernardos" ;
                                          dc:description "La ontología de Cubo de Datos Turísticos describe la estructura de los datos de ocupación turística, flujo turístico e indicadores en un único DSD que reúne todas las dimensiones y medidas."@es ,
                                                         "The Tourism Data Cube ontology describes the structure of tourist occupancy, tourist flow and indicator data in a single DSD that gathers all dimensions and measures."@en ;
                                          dc:license <https://creativecommons.org/licenses/by/4.0/> ;
                                          dc:title "Ontología de Cubo de Datos Turísticos"@es ,
                                                   "Tourism Data Cube Ontology"@en ;
                                          vann:preferredNamespacePrefix "edinttur" ;
                                          vann:preferredNamespaceUri edinttur: ;
                                          owl:versionInfo "0.1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
dc:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dc:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  https://www.w3.org/TR/vocab-data-cube/codeList
qb:codeList rdf:type owl:AnnotationProperty .


###  https://www.w3.org/TR/vocab-data-cube/component
qb:component rdf:type owl:AnnotationProperty .


###  https://www.w3.org/TR/vocab-data-cube/dimension
qb:dimension rdf:type owl:AnnotationProperty .


###  https://www.w3.org/TR/vocab-data-cube/measure
qb:measure rdf:type owl:AnnotationProperty .


###  https://www.w3.org/TR/vocab-data-cube/order
qb:order rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/linked-data/sdmx/2009/dimension#refArea
sdmx-dimension:refArea rdf:type owl:ObjectProperty .


###  http://purl.org/linked-data/sdmx/2009/dimension#refPeriod
sdmx-dimension:refPeriod rdf:type owl:ObjectProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/dimension#countryOfResidence
edintdimension:countryOfResidence rdf:type owl:ObjectProperty ;
                                  rdfs:range skos:Concept .


###  http://vocab.linkeddata.es/datosabiertos/def/dimension#flowType
edintdimension:flowType rdf:type owl:ObjectProperty ;
                        rdfs:range skos:Concept .


###  http://vocab.linkeddata.es/datosabiertos/def/dimension#refAdminRegion
edintdimension:refAdminRegion rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf sdmx-dimension:refArea ;
                              rdfs:range [ rdf:type owl:Class ;
                                           owl:unionOf ( esadm:Barrio
                                                         esadm:Distrito
                                                         esadm:Municipio
                                                       )
                                         ] .


###  http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod
edintdimension:refPeriod rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf sdmx-dimension:refPeriod ;
                         rdfs:range time:Interval .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/linked-data/sdmx/2009/measure#obsValue
sdmx-measure:obsValue rdf:type owl:DatatypeProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/dimension#registrationNumber
edintdimension:registrationNumber rdf:type owl:DatatypeProperty ;
                                  rdfs:range xsd:string .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#availablePlaces
edintmeasure:availablePlaces rdf:type owl:DatatypeProperty ;
                             rdfs:subPropertyOf sdmx-measure:obsValue ;
                             rdfs:range xsd:nonNegativeInteger .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#averageStay
edintmeasure:averageStay rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf sdmx-measure:obsValue ;
                         rdfs:range xsd:decimal .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#degreeOccupation
edintmeasure:degreeOccupation rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf sdmx-measure:obsValue ;
                              rdfs:range xsd:decimal .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#growthOfPlaces
edintmeasure:growthOfPlaces rdf:type owl:DatatypeProperty ;
                            rdfs:subPropertyOf sdmx-measure:obsValue ;
                            rdfs:range xsd:decimal .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#intensityPerResident
edintmeasure:intensityPerResident rdf:type owl:DatatypeProperty ;
                                  rdfs:subPropertyOf sdmx-measure:obsValue ;
                                  rdfs:range xsd:decimal .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#numTourists
edintmeasure:numTourists rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf sdmx-measure:obsValue ;
                         rdfs:range xsd:nonNegativeInteger .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#numTravelers
edintmeasure:numTravelers rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf sdmx-measure:obsValue ;
                          rdfs:range xsd:nonNegativeInteger .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#occupiedPlaces
edintmeasure:occupiedPlaces rdf:type owl:DatatypeProperty ;
                            rdfs:subPropertyOf sdmx-measure:obsValue ;
                            rdfs:range xsd:nonNegativeInteger .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#overnightStays
edintmeasure:overnightStays rdf:type owl:DatatypeProperty ;
                            rdfs:subPropertyOf sdmx-measure:obsValue ;
                            rdfs:range xsd:nonNegativeInteger .


#################################################################
#    Classes
#################################################################

###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio
esadm:Barrio rdf:type owl:Class ;
             rdfs:comment "A neighborhood is each of the parts into which large towns or their districts are divided [source: DRAE 2011]."@en ,
                          "Un barrio es cada una de las partes en que se dividen los pueblos grandes o sus distritos [fuente: DRAE 2011]."@es ;
             rdfs:label "Barrio"@es ,
                        "Neighbourhood"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito
esadm:Distrito rdf:type owl:Class ;
               rdfs:comment "Un distrito es cada una de las demarcaciones en que se subdivide un territorio o una población para distribuir y ordenar el ejercicio de los derechos civiles y políticos [fuente: DRAE 2011]."@es ;
               rdfs:label "District"@en ,
                          "Distrito"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio
esadm:Municipio rdf:type owl:Class ;
                rdfs:comment "Ente local definido en el artículo 140 de la Constitución española y entidad básica de la organización territorial del Estado según el artículo 1 de la Ley 7/1985."@es ;
                rdfs:label "Municipality"@en ,
                           "Municipio"@es .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class .


###  http://www.w3.org/2006/time#Interval
time:Interval rdf:type owl:Class .


###  https://www.w3.org/TR/vocab-data-cube/CodedProperty
qb:CodedProperty rdf:type owl:Class .


###  https://www.w3.org/TR/vocab-data-cube/DataStructureDefinition
qb:DataStructureDefinition rdf:type owl:Class .


###  https://www.w3.org/TR/vocab-data-cube/DimensionProperty
qb:DimensionProperty rdf:type owl:Class .


###  https://www.w3.org/TR/vocab-data-cube/MeasureProperty
qb:MeasureProperty rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://vocab.linkeddata.es/datosabiertos/def/dimension#countryOfResidence
edintdimension:countryOfResidence rdf:type owl:NamedIndividual ,
                                           qb:CodedProperty ,
                                           qb:DimensionProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/dimension#flowType
edintdimension:flowType rdf:type owl:NamedIndividual ,
                                 qb:CodedProperty ,
                                 qb:DimensionProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/dimension#refAdminRegion
edintdimension:refAdminRegion rdf:type owl:NamedIndividual ,
                                       qb:DimensionProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod
edintdimension:refPeriod rdf:type owl:NamedIndividual ,
                                  qb:DimensionProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/dimension#registrationNumber
edintdimension:registrationNumber rdf:type owl:NamedIndividual ,
                                           qb:DimensionProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#availablePlaces
edintmeasure:availablePlaces rdf:type owl:NamedIndividual ,
                                      qb:MeasureProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#averageStay
edintmeasure:averageStay rdf:type owl:NamedIndividual ,
                                  qb:MeasureProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#degreeOccupation
edintmeasure:degreeOccupation rdf:type owl:NamedIndividual ,
                                       qb:MeasureProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#growthOfPlaces
edintmeasure:growthOfPlaces rdf:type owl:NamedIndividual ,
                                     qb:MeasureProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#intensityPerResident
edintmeasure:intensityPerResident rdf:type owl:NamedIndividual ,
                                           qb:MeasureProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#numTourists
edintmeasure:numTourists rdf:type owl:NamedIndividual ,
                                  qb:MeasureProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#numTravelers
edintmeasure:numTravelers rdf:type owl:NamedIndividual ,
                                   qb:MeasureProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#occupiedPlaces
edintmeasure:occupiedPlaces rdf:type owl:NamedIndividual ,
                                     qb:MeasureProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/measure#overnightStays
edintmeasure:overnightStays rdf:type owl:NamedIndividual ,
                                     qb:MeasureProperty .


###  http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#DSD_Tourism
edinttur:DSD_Tourism rdf:type owl:NamedIndividual ,
                              qb:DataStructureDefinition ;
                     rdfs:comment "Estructura de datos integrada que combina las dimensiones y medidas de los cubos de ocupación turística, flujo turístico e indicadores turísticos."@es ;
                     rdfs:label "DSD integrado de turismo"@es ,
                                "Integrated tourism DSD"@en ;
                     qb:component [ qb:measure edintmeasure:numTourists
                                  ] ,
                                  [ qb:dimension edintdimension:countryOfResidence ;
                                    qb:order 3
                                  ] ,
                                  [ qb:dimension edintdimension:refPeriod ;
                                    qb:order 2
                                  ] ,
                                  [ qb:dimension edintdimension:refAdminRegion ;
                                    qb:order 1
                                  ] ,
                                  [ qb:measure edintmeasure:degreeOccupation
                                  ] ,
                                  [ qb:measure edintmeasure:averageStay
                                  ] ,
                                  [ qb:dimension edintdimension:registrationNumber ;
                                    qb:order 5
                                  ] ,
                                  [ qb:dimension edintdimension:flowType ;
                                    qb:order 4
                                  ] ,
                                  [ qb:measure edintmeasure:intensityPerResident
                                  ] ,
                                  [ qb:measure edintmeasure:growthOfPlaces
                                  ] ,
                                  [ qb:measure edintmeasure:overnightStays
                                  ] ,
                                  [ qb:measure edintmeasure:occupiedPlaces
                                  ] ,
                                  [ qb:measure edintmeasure:numTravelers
                                  ] ,
                                  [ qb:measure edintmeasure:availablePlaces
                                  ] .


###  http://vocab.linkeddata.es/datosabiertos/kos/edint/TourismFlowType
edintkos:TourismFlowType rdf:type owl:NamedIndividual ,
                                  skos:ConceptScheme ;
                         rdfs:label "Tipo de flujo turístico"@es ,
                                    "Tourism flow type"@en .


###  http://vocab.linkeddata.es/datosabiertos/kos/edint/country
edintkos:country rdf:type owl:NamedIndividual ,
                          skos:ConceptScheme ;
                 rdfs:label "Country"@en ,
                            "País"@es .


#################################################################
#    Annotations
#################################################################

edintdimension:countryOfResidence rdfs:label "country of residence"@en ;
                                  rdfs:comment "País de residencia del turista."@es ;
                                  rdfs:label "país de residencia"@es ;
                                  rdfs:comment "Country of residence of the tourist."@en ;
                                  qb:codeList edintkos:country .


edintdimension:flowType qb:codeList edintkos:TourismFlowType ;
                        rdfs:comment "Type of tourist flow (national, international, interprovintial)."@en ;
                        rdfs:label "tipo de flujo"@es ,
                                   "flow type"@en ;
                        rdfs:comment "Tipo de flujo turístico (nacional, internacional, interprovincial)."@es .


edintdimension:refAdminRegion rdfs:comment "Referencia a una región administrativa que puede ser un barrio, distrito o municipio."@es ;
                              rdfs:label "reference administrative region"@en ,
                                         "región administrativa de referencia"@es ;
                              rdfs:comment "Reference to an administrative region that can be a neighborhood, district, or municipality."@en .


edintdimension:refPeriod rdfs:comment "Time interval that can be, for example, a week, a month, a year."@en ;
                         rdfs:label "período de referencia"@es ;
                         rdfs:comment "Intervalo de tiempo que puede ser por ejemplo una semana, un mes, un año."@es ;
                         rdfs:label "reference period"@en .


edintdimension:registrationNumber rdfs:label "registration number (Segittur)"@en ,
                                             "número de registro (Segittur)"@es ;
                                  rdfs:comment "Tourist accommodation registration number as defined by Segittur."@en ,
                                               "Número de registro del establecimiento turístico según Segittur."@es .


edintmeasure:availablePlaces rdfs:label "available places"@en ;
                             rdfs:comment "Beda available in Accomodations"@en ;
                             rdfs:label "plazas disponibles"@es ;
                             rdfs:comment "Plazas disponibles en alojamientos."@es .


edintmeasure:averageStay rdfs:comment "Número de pernoctas en promedio. Mide el número total de pernoctas entre el número total de turistas."@es ;
                         rdfs:label "estancia media"@es ,
                                    "average stay"@en ;
                         rdfs:comment "Average number of overnight stays. Measures the total number of overnight stays divided by the total number of tourists."@en .


edintmeasure:degreeOccupation rdfs:comment "Occupancy rate, which allows for the detection of peak tourist periods. It measures the total number of occupied beds relative to the total number of available beds during a given period."@en ;
                              rdfs:label "grado de ocupación"@es ;
                              rdfs:comment "Grado de uso del alojamiento que permite detectar períodos de alta ocupación turística. Mide el total de plazas ocupadas sobre el total de plazas disponibles en un determinado período."@es ;
                              rdfs:label "occupancy rate"@en .


edintmeasure:growthOfPlaces rdfs:comment "The evolution of accommodation capacity over a given period allows us to determine if it is expanding, stable, or declining. It measures the percentage change in accommodation capacity in a certain period with respect to the previous period."@en ;
                            rdfs:label "growth of places"@en ;
                            rdfs:comment "Evolución de la capacidad alojativa en un período dado permitiendo conocer si está en expansión, estabilidad o recucción. Mide la variación porcentual de la capacidad alojativa de un período con respecto al período anterior."@es ;
                            rdfs:label "crecimiento de plazas"@es .


edintmeasure:intensityPerResident rdfs:label "intensity per resident"@en ;
                                  rdfs:comment "Presión turística en un área determinada. Mide la relación entre el número de visitantes y el número de residentes en la zona."@es ,
                                               "Tourist pressure in a given area. It measures the relationship between the number of visitors and the number of residents in the area."@en ;
                                  rdfs:label "intensidad por residente"@es .


edintmeasure:numTourists rdfs:label "número de turistas"@es ;
                         rdfs:comment "Total number national, international, and interprovincial tourists that pass through a tourist site."@en ;
                         rdfs:label "number of tourists"@en ;
                         rdfs:comment "Total number of national, international and interprovincial tourists passing through a tourist site."@es .


edintmeasure:numTravelers rdfs:comment "Number of travelers in general. May be tourism or business travelers."@en ,
                                       "Número de viajeros en general. Pueden ser viajeros de turismo o negocios."@es ;
                          rdfs:label "número de viajeros"@es ,
                                     "number of travelers"@en .


edintmeasure:occupiedPlaces rdfs:label "occupied places"@en ;
                            rdfs:comment "Número total de plazas que se han ocupado."@es ;
                            rdfs:label "plazas ocupadas"@es ;
                            rdfs:comment "Total number of places that have been occupied."@en .


edintmeasure:overnightStays rdfs:comment "Total number of overnight stays per person."@en ;
                            rdfs:label "pernoctaciones"@es ;
                            rdfs:comment "Número total de pernoctas por persona."@es ;
                            rdfs:label "overnight stays"@en .


